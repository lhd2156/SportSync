# =============================================================================
# SportSync Environment Variables Template
# Copy this file to backend/.env or your deployment secrets store.
# Never commit real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime mode
# Local-safe value: development
# Production value: production
# -----------------------------------------------------------------------------
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Logging
# Local-safe value: DEBUG
# Production value: INFO
# -----------------------------------------------------------------------------
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# Database
# Local-safe value: postgresql://sportsync:sportsync@localhost:5432/sportsync
# Production value: your managed PostgreSQL connection string
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://sportsync:sportsync@localhost:5432/sportsync
DATABASE_AUTO_CREATE=false

# -----------------------------------------------------------------------------
# Redis
# Local-safe value: redis://localhost:6379/0
# Production value: your managed Redis connection string
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CHANNEL_LIVE_SCORES=scores:live

# -----------------------------------------------------------------------------
# JWT / Auth
# Local-safe value: generate a dev-only secret with at least 32 characters
# Production value: a long random secret from your secret manager
# -----------------------------------------------------------------------------
JWT_SECRET=replace-with-a-32-character-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
JWT_REMEMBER_ME_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Google OAuth
# Local-safe value: localhost-enabled Google OAuth client
# Production value: production Google OAuth client
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# -----------------------------------------------------------------------------
# SMTP / transactional email
# Local-safe value: leave blank unless testing a real mailbox
# Production value: your Namecheap/Private Email SMTP mailbox credentials
# EMAIL_DELIVERY_PROVIDER options: smtp | ses | auto
# -----------------------------------------------------------------------------
EMAIL_DELIVERY_PROVIDER=smtp
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_USERNAME=noreply@onsportsync.com
SMTP_PASSWORD=replace-with-mailbox-password
SMTP_FROM_EMAIL=noreply@onsportsync.com
SMTP_FROM_NAME=SportSync
SMTP_USE_TLS=true
SMTP_USE_SSL=false
AWS_SES_CONFIGURATION_SET=

# -----------------------------------------------------------------------------
# TheSportsDB
# Local-safe value: your development API key
# Production value: your production API key
# -----------------------------------------------------------------------------
SPORTSDB_API_KEY=replace-with-sportsdb-key

# -----------------------------------------------------------------------------
# AWS
# Local-safe value: leave blank if not testing S3 locally
# Production value: IAM-backed application credentials or role-based auth
# -----------------------------------------------------------------------------
AWS_S3_BUCKET=replace-with-s3-bucket
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_ENDPOINT_URL=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_USE_PATH_STYLE=false

# -----------------------------------------------------------------------------
# CORS / Redirect allowlist
# Local-safe value: http://localhost:5173,http://localhost:5174
# Production value: https://onsportsync.com
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
PRODUCTION_DOMAIN=https://onsportsync.com
REDIRECT_ALLOWLIST=http://localhost:5173,http://localhost:5174,https://onsportsync.com,https://www.onsportsync.com
COOKIE_DOMAIN=
COOKIE_SAMESITE=strict
# Use false only for temporary HTTP deployments on a raw EC2 public IP.
COOKIE_SECURE_OVERRIDE=

# =============================================================================
# Frontend (frontend/.env)
# =============================================================================
# Local-safe value: http://localhost:8000
# Production value: https://onsportsync.com/api
# VITE_API_BASE_URL=http://localhost:8000
#
# Local-safe value: leave blank for same-origin or point at your object store root
# Production value: https://onsportsync.com/
# VITE_ASSET_BASE_URL=
#
# Local-safe value: ws://localhost:8080
# Production value: wss://onsportsync.com/ws
# VITE_WS_URL=ws://localhost:8080
#
# Local-safe value: localhost-enabled Google client
# Production value: production Google client
# VITE_GOOGLE_CLIENT_ID=replace-with-google-client-id
#
# Local-safe value: http://localhost:5173,http://localhost:5174
# Production value: https://onsportsync.com
# VITE_ALLOWED_REDIRECT_ORIGINS=http://localhost:5173,http://localhost:5174,https://onsportsync.com,https://www.onsportsync.com
